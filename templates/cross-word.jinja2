{% import "/templates/shared/macros.jinja2" as macros with context %}
<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <title>Crossword - Addicting Word Games</title>
    {{ macros.headers(ws, highscores, achievements) }}
    <script src="{{ static_url }}/js/game-audio.js"></script>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            margin: 0;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh;
            color: #fff;
        }
        .game-container { max-width: 1100px; margin: 0 auto; padding: 20px; }
        h1 { font-size: 2em; margin: 10px 0; text-align: center; }
        .subtitle { color: #a0aec0; margin-bottom: 15px; font-size: 0.9em; text-align: center; }
        .game-layout { display: flex; gap: 30px; flex-wrap: wrap; justify-content: center; }
        .grid-container { flex: 0 0 auto; }
        #crossword-grid {
            display: grid;
            gap: 2px;
            background: #2d3748;
            padding: 8px;
            border-radius: 8px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.4);
        }
        .cell {
            width: 36px; height: 36px;
            background: #fff;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2em;
            font-weight: bold;
            color: #1a1a2e;
            cursor: pointer;
            position: relative;
            text-transform: uppercase;
        }
        .cell.blocked { background: #1a1a2e; cursor: default; }
        .cell.selected { background: #68d391; }
        .cell.highlighted { background: #bee3f8; }
        .cell.correct { background: #c6f6d5; }
        .cell.revealed { background: #fefcbf; color: #744210; }
        .cell-number {
            position: absolute;
            top: 2px; left: 3px;
            font-size: 0.5em;
            font-weight: normal;
            color: #666;
        }
        .clues-container { flex: 1; min-width: 280px; max-width: 400px; }
        .clues-section { margin-bottom: 20px; }
        .clues-section h3 { margin: 0 0 10px; color: #68d391; font-size: 1em; }
        .clue-list { list-style: none; padding: 0; margin: 0; }
        .clue-item {
            padding: 8px 12px;
            margin-bottom: 4px;
            background: rgba(255,255,255,0.05);
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.9em;
            transition: all 0.15s;
        }
        .clue-item:hover { background: rgba(255,255,255,0.1); }
        .clue-item.active { background: rgba(104,211,145,0.2); border-left: 3px solid #68d391; }
        .clue-item.solved { color: #68d391; text-decoration: line-through; opacity: 0.7; }
        .clue-number { font-weight: bold; color: #68d391; margin-right: 8px; }
        .controls { display: flex; gap: 10px; justify-content: center; margin: 20px 0; flex-wrap: wrap; }
        .btn {
            padding: 10px 20px;
            font-size: 1em;
            background: #4a5568;
            color: #fff;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn:hover { background: #5a6578; transform: translateY(-2px); }
        .btn.primary { background: #68d391; color: #1a1a2e; }
        .btn.primary:hover { background: #48bb78; }
        select {
            padding: 10px 16px;
            font-size: 1em;
            background: #4a5568;
            color: #fff;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }
        #message { text-align: center; font-size: 1.2em; font-weight: bold; margin: 15px 0; min-height: 30px; }
        #message.success { color: #68d391; }
        #message.error { color: #fc8181; }
        .stats { display: flex; justify-content: center; gap: 30px; margin: 15px 0; font-size: 0.95em; }
        .stats span { color: #a0aec0; }
        .stats strong { color: #fff; }
        .music-controls {
            position: fixed; bottom: 20px; right: 20px;
            background: rgba(45,55,72,0.95); padding: 12px;
            border-radius: 10px; font-size: 0.85em; z-index: 100;
        }
        .music-controls button {
            padding: 6px 12px; margin: 2px;
            background: #4a5568; color: #fff;
            border: none; border-radius: 5px; cursor: pointer;
        }
        .music-controls button:hover { background: #5a6578; }
        .music-controls .song-name { color: #a0aec0; margin-top: 6px; font-size: 0.85em; }
        .volume-row { display: flex; align-items: center; gap: 6px; margin-top: 6px; }
        .volume-row input { width: 70px; }
        .volume-row label { font-size: 0.75em; color: #a0aec0; width: 28px; }
        .fullscreen-btn {
            position: fixed; top: 10px; right: 10px;
            padding: 8px 14px; background: rgba(0,0,0,0.7);
            border: 1px solid #4a5568; border-radius: 6px;
            color: #fff; cursor: pointer; z-index: 100; font-size: 0.9em;
        }
        .fullscreen-btn:hover { background: rgba(74,85,104,0.9); }
        :fullscreen .game-container { max-width: 100%; }
        :fullscreen #pagebody > *:not(.game-container):not(.music-controls):not(.fullscreen-btn) { display: none; }
        @keyframes pop { 50% { transform: scale(1.1); } }
        @keyframes shake { 25%,75% { transform: translateX(-3px); } 50% { transform: translateX(3px); } }
        .pop { animation: pop 0.2s; }
        .shake { animation: shake 0.3s; }
    </style>
</head>
<body>
{{ macros.templates() }}
<div id="pagebody">
    {{ macros.topbar() }}
    <div class="game-container">
        <h1>Crossword</h1>
        <p class="subtitle">Fill in the grid using the clues. Click a cell or clue to start typing!</p>

        <div class="controls">
            <select id="difficulty">
                <option value="easy">Easy (8x8)</option>
                <option value="medium" selected>Medium (10x10)</option>
                <option value="hard">Hard (12x12)</option>
            </select>
            <button class="btn primary" id="new-game">New Game</button>
            <button class="btn" id="check-btn">Check</button>
            <button class="btn" id="reveal-btn">Reveal Word</button>
            <button class="btn" id="clear-btn">Clear</button>
        </div>

        <div class="stats">
            <span>Words: <strong id="words-solved">0</strong>/<strong id="words-total">0</strong></span>
            <span>Time: <strong id="timer">0:00</strong></span>
        </div>

        <div id="message"></div>

        <div class="game-layout">
            <div class="grid-container">
                <div id="crossword-grid"></div>
            </div>
            <div class="clues-container">
                <div class="clues-section">
                    <h3>Across</h3>
                    <ul class="clue-list" id="across-clues"></ul>
                </div>
                <div class="clues-section">
                    <h3>Down</h3>
                    <ul class="clue-list" id="down-clues"></ul>
                </div>
            </div>
        </div>
    </div>

    <button class="fullscreen-btn" id="fullscreen-btn">Fullscreen</button>
    <div class="music-controls">
        <button id="music-toggle">Play Music</button>
        <button id="music-next">Next</button>
        <div class="song-name" id="song-name"></div>
        <div class="volume-row"><label>SFX</label><input type="range" id="sfx-vol" min="0" max="100" value="70"></div>
        <div class="volume-row"><label>Music</label><input type="range" id="music-vol" min="0" max="100" value="50"></div>
    </div>
    {{ macros.footer() }}
</div>
