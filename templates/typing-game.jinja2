{% import "/templates/shared/macros.jinja2" as macros with context %}
<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <title>Typing Game - Addicting Word Games</title>
    {{ macros.headers(ws, highscores, achievements) }}
    <script src="{{ static_url }}/js/game-audio.js"></script>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            margin: 0;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh;
            color: #fff;
        }
        .game-container { max-width: 700px; margin: 0 auto; padding: 20px; text-align: center; }
        h1 { font-size: 2em; margin: 10px 0; }
        .subtitle { color: #888; margin-bottom: 15px; font-size: 0.9em; }
        #gameCanvas {
            display: block; margin: 0 auto;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        }
        #hud {
            display: flex; justify-content: center; gap: 30px;
            margin: 15px 0; font-size: 1.1em;
        }
        #hud > div { padding: 8px 16px; background: rgba(0,0,0,0.3); border-radius: 8px; }
        .health { color: #fc8181; }
        .score { color: #68d391; }
        .combo { color: #f6e05e; }
        .level { color: #63b3ed; }
        .music-controls {
            position: fixed; bottom: 20px; right: 20px;
            background: rgba(45,55,72,0.95); padding: 12px;
            border-radius: 10px; font-size: 0.85em;
        }
        .music-controls button {
            padding: 6px 12px; margin: 2px;
            background: #4a5568; color: #fff;
            border: none; border-radius: 5px; cursor: pointer;
        }
        .music-controls button:hover { background: #5a6578; }
        .music-controls .song-name { color: #a0aec0; margin-top: 6px; font-size: 0.85em; }
        .volume-row { display: flex; align-items: center; gap: 6px; margin-top: 6px; }
        .volume-row input { width: 70px; }
        .volume-row label { font-size: 0.75em; color: #a0aec0; width: 28px; }
        .fullscreen-btn {
            position: fixed; top: 10px; right: 10px;
            padding: 8px 14px; background: rgba(0,0,0,0.7);
            border: 1px solid #4a5568; border-radius: 6px;
            color: #fff; cursor: pointer; z-index: 100; font-size: 0.9em;
        }
        .fullscreen-btn:hover { background: rgba(74,85,104,0.9); }
        :fullscreen .game-container { max-width: 100%; }
        :fullscreen #gameCanvas { width: 90vw; max-height: 65vh; height: auto; }
        :fullscreen #pagebody > *:not(.game-container):not(.music-controls):not(.fullscreen-btn) { display: none; }
        .wpm { color: #b794f4; }
        .mode-btns { display: flex; justify-content: center; gap: 10px; margin: 10px 0; }
        .mode-btn { padding: 8px 16px; background: rgba(0,0,0,0.3); border: 1px solid #4a5568; border-radius: 6px; color: #fff; cursor: pointer; }
        .mode-btn:hover { border-color: #68d391; }
        .mode-btn.active { border-color: #68d391; background: rgba(104,211,145,0.2); }
        .powerup { position: absolute; padding: 4px 8px; border-radius: 4px; font-size: 0.8em; font-weight: bold; animation: float 2s ease-in-out infinite; }
        @keyframes float { 50% { transform: translateY(-5px); } }
    </style>
</head>
<body>
{{ macros.templates() }}
<div id="pagebody">
    {{ macros.topbar() }}
    <div class="game-container">
        <h1>Typing Game</h1>
        <p class="subtitle">Type the falling letters before they hit the ground!</p>
        <canvas id="gameCanvas" width="650" height="450"></canvas>
        <div id="hud">
            <div class="health">Health: <strong id="health">5</strong></div>
            <div class="score">Score: <strong id="score">0</strong></div>
            <div class="combo">Combo: <strong id="combo">0</strong></div>
            <div class="level">Level: <strong id="level">1</strong></div>
            <div class="wpm">WPM: <strong id="wpm">0</strong></div>
        </div>
        <div class="mode-btns">
            <button class="mode-btn active" data-mode="letters">Letters</button>
            <button class="mode-btn" data-mode="words">Words</button>
        </div>
    </div>
    <button class="fullscreen-btn" id="fullscreen-btn">Fullscreen</button>
    <div class="music-controls">
        <button id="music-toggle">Play Music</button>
        <button id="music-next">Next</button>
        <div class="song-name" id="song-name"></div>
        <div class="volume-row"><label>SFX</label><input type="range" id="sfx-vol" min="0" max="100" value="70"></div>
        <div class="volume-row"><label>Music</label><input type="range" id="music-vol" min="0" max="100" value="50"></div>
    </div>
    {{ macros.footer() }}
</div>
<script>
(function(){
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const audio = new GameAudio();
    const W = canvas.width, H = canvas.height;

    const WORDS = ['cat','dog','run','sun','hat','box','pen','cup','red','big','tree','fish','bird','lamp','rock',
        'moon','star','fire','wind','snow','house','water','light','dream','storm','cloud','flame','steel','stone'];
    const colors = ['#fc8181','#68d391','#63b3ed','#f6e05e','#b794f4','#f687b3'];

    let items = [], particles = [], powerups = [], screenShake = 0;
    let health = 5, score = 0, combo = 0, level = 1, mode = 'letters';
    let lastSpawn = 0, gameOver = false, startTime = 0, totalChars = 0;
    let currentWord = '', freezeTimer = 0, shieldActive = false;

    const testMode = new URLSearchParams(window.location.search).get('test') === 'true';
    let testTimer = 0, testPassed = false;

    // Volume & fullscreen
    document.getElementById('sfx-vol').oninput = e => audio.setSfxVolume(e.target.value/100);
    document.getElementById('music-vol').oninput = e => audio.setMusicVolume(e.target.value/100);
    document.getElementById('fullscreen-btn').onclick = () => {
        if(!document.fullscreenElement) document.documentElement.requestFullscreen();
        else document.exitFullscreen();
    };
    document.addEventListener('fullscreenchange', () => {
        document.getElementById('fullscreen-btn').textContent = document.fullscreenElement ? 'Exit' : 'Fullscreen';
    });

    // Mode buttons
    document.querySelectorAll('.mode-btn').forEach(btn => {
        btn.onclick = function() {
            document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            mode = this.dataset.mode;
            reset();
        };
    });

    function spawn() {
        if(mode === 'letters') {
            items.push({
                text: String.fromCharCode(65 + Math.floor(Math.random()*26)),
                x: 40 + Math.random()*(W-80), y: -30,
                color: colors[Math.floor(Math.random()*colors.length)],
                speed: freezeTimer > 0 ? 0.5 : (1.5 + level * 0.3 + Math.random() * 0.5),
                size: 28 + Math.floor(Math.random()*8), typed: 0
            });
        } else {
            const word = WORDS[Math.floor(Math.random()*WORDS.length)].toUpperCase();
            items.push({
                text: word, x: 60 + Math.random()*(W-120), y: -30,
                color: colors[Math.floor(Math.random()*colors.length)],
                speed: freezeTimer > 0 ? 0.3 : (0.8 + level * 0.15 + Math.random() * 0.3),
                size: 22, typed: 0
            });
        }
        audio.spawn();
        // Random powerup spawn
        if(Math.random() < 0.08 && powerups.length < 2) spawnPowerup();
    }

    function spawnPowerup() {
        const types = [{type:'freeze',color:'#63b3ed',text:'FREEZE'},{type:'clear',color:'#68d391',text:'CLEAR'},
            {type:'shield',color:'#f6e05e',text:'SHIELD'},{type:'health',color:'#fc8181',text:'+LIFE'}];
        const p = types[Math.floor(Math.random()*types.length)];
        powerups.push({...p, x: 40 + Math.random()*(W-80), y: -30, speed: 1 + Math.random()});
    }

    function activatePowerup(p) {
        audio.powerUp();
        if(p.type === 'freeze') { freezeTimer = 5; items.forEach(i => i.speed *= 0.3); }
        else if(p.type === 'clear') { items.forEach(i => createParticles(i.x, i.y, i.color, 8)); items = []; score += 5; }
        else if(p.type === 'shield') { shieldActive = true; setTimeout(() => shieldActive = false, 8000); }
        else if(p.type === 'health') { health = Math.min(health + 1, 10); }
        updateHud();
    }

    function createParticles(x, y, color, count=12) {
        for(let i=0; i<count; i++) {
            const a = Math.random()*Math.PI*2, sp = 2 + Math.random()*4;
            particles.push({x,y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp,color,life:1,size:3+Math.random()*3});
        }
    }

    function shake(amt) { screenShake = Math.max(screenShake, amt); }

    function updateHud() {
        document.getElementById('health').textContent = health + (shieldActive ? ' [S]' : '');
        document.getElementById('score').textContent = score;
        document.getElementById('combo').textContent = combo > 1 ? combo + 'x' : '-';
        document.getElementById('level').textContent = level;
        const elapsed = (Date.now() - startTime) / 60000;
        const wpm = elapsed > 0 ? Math.round((totalChars / 5) / elapsed) : 0;
        document.getElementById('wpm').textContent = wpm;
    }

    function reset() {
        items = []; particles = []; powerups = [];
        health = 5; score = 0; combo = 0; level = 1;
        gameOver = false; lastSpawn = 0; startTime = Date.now(); totalChars = 0;
        currentWord = ''; freezeTimer = 0; shieldActive = false; screenShake = 0;
        updateHud();
    }

    function update(time) {
        if(!lastSpawn) lastSpawn = time;
        const spawnRate = mode === 'letters' ? Math.max(400, 1200 - level * 100) : Math.max(800, 2000 - level * 150);
        if(time - lastSpawn > spawnRate && !gameOver) { spawn(); lastSpawn = time; }
        if(freezeTimer > 0) freezeTimer -= 1/60;

        ctx.save();
        if(screenShake > 0) {
            ctx.translate(Math.random()*screenShake - screenShake/2, Math.random()*screenShake - screenShake/2);
            screenShake *= 0.9; if(screenShake < 0.5) screenShake = 0;
        }

        ctx.fillStyle = 'rgba(26,26,46,0.25)'; ctx.fillRect(0,0,W,H);

        // Particles
        for(let i = particles.length-1; i >= 0; i--) {
            const p = particles[i];
            p.x += p.vx; p.y += p.vy; p.vy += 0.1; p.life -= 0.025;
            ctx.globalAlpha = p.life; ctx.fillStyle = p.color;
            ctx.beginPath(); ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI*2); ctx.fill();
            if(p.life <= 0) particles.splice(i,1);
        }
        ctx.globalAlpha = 1;

        // Powerups
        for(let i = powerups.length-1; i >= 0; i--) {
            const p = powerups[i];
            p.y += p.speed;
            ctx.fillStyle = p.color; ctx.font = 'bold 14px sans-serif'; ctx.textAlign = 'center';
            ctx.shadowBlur = 10; ctx.shadowColor = p.color;
            ctx.fillText(p.text, p.x, p.y);
            ctx.shadowBlur = 0;
            if(p.y > H + 20) powerups.splice(i,1);
        }

        // Items
        for(let i = items.length-1; i >= 0; i--) {
            const l = items[i];
            l.y += l.speed;
            ctx.shadowBlur = 20; ctx.shadowColor = l.color; ctx.fillStyle = l.color;
            ctx.font = `bold ${l.size}px sans-serif`; ctx.textAlign = 'center';
            if(mode === 'words' && l.typed > 0) {
                const t1 = l.text.substring(0, l.typed), t2 = l.text.substring(l.typed);
                const w = ctx.measureText(l.text).width;
                ctx.textAlign = 'left';
                ctx.fillStyle = '#68d391'; ctx.fillText(t1, l.x - w/2, l.y);
                ctx.fillStyle = l.color; ctx.fillText(t2, l.x - w/2 + ctx.measureText(t1).width, l.y);
            } else {
                ctx.fillText(l.text, l.x, l.y);
            }
            ctx.shadowBlur = 0;

            if(l.y > H + 20) {
                items.splice(i,1);
                if(!shieldActive) { health--; shake(5); audio.loseLife(); }
                combo = 0; currentWord = '';
                updateHud();
                if(health <= 0 && !gameOver) { gameOver = true; audio.gameOver(); }
            }
        }

        // Level up
        const newLevel = Math.floor(score / (mode === 'letters' ? 15 : 10)) + 1;
        if(newLevel > level) { level = newLevel; audio.waveComplete(); updateHud(); }

        if(gameOver) {
            ctx.fillStyle = 'rgba(0,0,0,0.8)'; ctx.fillRect(0,0,W,H);
            ctx.fillStyle = '#fc8181'; ctx.font = 'bold 40px sans-serif'; ctx.textAlign = 'center';
            ctx.fillText('GAME OVER', W/2, H/2 - 30);
            ctx.fillStyle = '#fff'; ctx.font = '24px sans-serif';
            ctx.fillText(`Score: ${score}  |  Level: ${level}`, W/2, H/2 + 10);
            const elapsed = (Date.now() - startTime) / 60000;
            const wpm = elapsed > 0 ? Math.round((totalChars / 5) / elapsed) : 0;
            ctx.fillText(`WPM: ${wpm}`, W/2, H/2 + 45);
            ctx.fillStyle = '#a0aec0'; ctx.font = '16px sans-serif';
            ctx.fillText('Press SPACE to restart', W/2, H/2 + 80);
        }

        ctx.restore();
        if(testMode) runTest();
        requestAnimationFrame(update);
    }

    document.addEventListener('keydown', e => {
        if(gameOver) { if(e.code === 'Space') reset(); return; }
        const key = e.key.toUpperCase();
        if(key.length !== 1 || key < 'A' || key > 'Z') return;

        // Check powerups first
        for(let i = 0; i < powerups.length; i++) {
            if(powerups[i].text[0] === key) {
                activatePowerup(powerups[i]);
                createParticles(powerups[i].x, powerups[i].y, powerups[i].color, 15);
                powerups.splice(i, 1);
                return;
            }
        }

        if(mode === 'letters') {
            for(let i = 0; i < items.length; i++) {
                if(items[i].text === key) {
                    createParticles(items[i].x, items[i].y, items[i].color);
                    items.splice(i,1);
                    score++; combo++; totalChars++;
                    audio.combo(Math.min(combo, 10));
                    updateHud(); return;
                }
            }
        } else {
            let target = items.find(i => i.typed > 0);
            if(!target) target = items.find(i => i.text[0] === key);
            if(target) {
                if(target.text[target.typed] === key) {
                    target.typed++; totalChars++;
                    audio.type();
                    if(target.typed === target.text.length) {
                        createParticles(target.x, target.y, target.color, 20);
                        items.splice(items.indexOf(target), 1);
                        score += target.text.length; combo++;
                        audio.combo(Math.min(combo, 10));
                    }
                    updateHud();
                } else {
                    target.typed = 0; combo = 0; audio.wrong(); shake(3);
                    updateHud();
                }
            }
        }
    });

    let musicPlaying = false;
    document.getElementById('music-toggle').onclick = function() {
        if(musicPlaying) { audio.stopMusic(); this.textContent = 'Play Music'; }
        else { audio.startMusic(); this.textContent = 'Mute'; document.getElementById('song-name').textContent = audio.getSongName(); }
        musicPlaying = !musicPlaying;
    };
    document.getElementById('music-next').onclick = function() {
        if(musicPlaying) { audio.nextSong(); document.getElementById('song-name').textContent = audio.getSongName(); }
    };

    function runTest() {
        if(!testMode || testPassed || gameOver) return;
        testTimer++;
        if(items.length > 0 && testTimer % 6 === 0) {
            const l = items[0];
            if(mode === 'letters') {
                createParticles(l.x, l.y, l.color);
                items.splice(0,1);
                score++; combo++; totalChars++;
            } else {
                l.typed++; totalChars++;
                if(l.typed >= l.text.length) {
                    createParticles(l.x, l.y, l.color, 20);
                    items.splice(0,1);
                    score += l.text.length; combo++;
                }
            }
            audio.combo(Math.min(combo, 10)); updateHud();
        }
        if(score >= 25 && !testPassed) {
            testPassed = true; console.log('TEST_PASSED: Score ' + score);
            document.body.insertAdjacentHTML('beforeend', '<div id="test-result" style="position:fixed;top:10px;left:10px;background:green;color:white;padding:10px;z-index:9999">TEST PASSED</div>');
        }
    }

    startTime = Date.now();
    requestAnimationFrame(update);
})();
</script>
</body>
</html>
