{% import "/templates/shared/macros.jinja2" as macros with context %}
<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <title>Infinite Wordle - Addicting Word Games</title>
    {{ macros.headers(ws, highscores, achievements) }}
    <script src="{{ static_url }}/js/game-audio.js"></script>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            margin: 0;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh;
            color: #fff;
        }
        .game-container {
            max-width: 500px;
            margin: 0 auto;
            padding: 20px;
            text-align: center;
        }
        h1 { font-size: 2em; margin: 10px 0; text-shadow: 0 2px 10px rgba(0,0,0,0.3); }
        .subtitle { color: #888; margin-bottom: 20px; font-size: 0.9em; }
        #board { margin: 20px 0; }
        .row { display: flex; justify-content: center; gap: 6px; margin-bottom: 6px; }
        .tile {
            width: 56px; height: 56px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.8em; font-weight: bold; text-transform: uppercase;
            border-radius: 8px;
            background: #2d3748;
            border: 2px solid #4a5568;
            transition: transform 0.1s;
        }
        .tile.pop { animation: pop 0.15s ease; }
        .tile.flip { animation: flip 0.5s ease forwards; }
        .tile.green { background: #48bb78; border-color: #48bb78; box-shadow: 0 0 15px rgba(72,187,120,0.4); }
        .tile.gold { background: #ecc94b; border-color: #ecc94b; color: #1a1a2e; box-shadow: 0 0 15px rgba(236,201,75,0.4); }
        .tile.gray { background: #4a5568; border-color: #4a5568; }
        @keyframes pop { 50% { transform: scale(1.1); } }
        @keyframes flip {
            0% { transform: rotateX(0); }
            50% { transform: rotateX(90deg); }
            100% { transform: rotateX(0); }
        }
        @keyframes shake { 25%,75% { transform: translateX(-5px); } 50% { transform: translateX(5px); } }
        @keyframes bounce { 50% { transform: translateY(-10px); } }
        .shake { animation: shake 0.3s; }
        .bounce { animation: bounce 0.5s; }
        #keyboard { margin: 20px 0; }
        .kb-row { display: flex; justify-content: center; gap: 4px; margin-bottom: 4px; }
        .key {
            min-width: 32px; height: 50px; padding: 0 10px;
            font-size: 0.9em; font-weight: bold;
            border: none; border-radius: 6px;
            background: #4a5568; color: #fff;
            cursor: pointer; transition: all 0.1s;
        }
        .key:hover { background: #5a6578; transform: translateY(-2px); }
        .key:active { transform: translateY(0); }
        .key.wide { min-width: 60px; font-size: 0.8em; }
        .key.green { background: #48bb78; }
        .key.gold { background: #ecc94b; color: #1a1a2e; }
        .key.gray { background: #2d3748; color: #666; }
        #stats { display: flex; justify-content: center; gap: 30px; margin: 15px 0; font-size: 0.9em; }
        #stats span { color: #a0aec0; }
        #stats strong { color: #fff; }
        #message { min-height: 40px; font-size: 1.3em; font-weight: bold; color: #48bb78; margin: 10px 0; }
        .btn-row { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; }
        .btn {
            padding: 12px 24px; font-size: 1em;
            background: #4299e1; color: #fff;
            border: none; border-radius: 8px;
            cursor: pointer; transition: all 0.2s;
        }
        .btn:hover { background: #3182ce; transform: translateY(-2px); }
        .btn.secondary { background: #4a5568; }
        .btn.secondary:hover { background: #5a6578; }
        .music-controls {
            position: fixed; bottom: 20px; right: 20px;
            background: rgba(45,55,72,0.95); padding: 12px;
            border-radius: 10px; font-size: 0.85em;
        }
        .music-controls button {
            padding: 6px 12px; margin: 2px;
            background: #4a5568; color: #fff;
            border: none; border-radius: 5px; cursor: pointer;
        }
        .music-controls button:hover { background: #5a6578; }
        .music-controls .song-name { color: #a0aec0; margin-top: 6px; font-size: 0.85em; }
        .volume-row { display: flex; align-items: center; gap: 6px; margin-top: 6px; }
        .volume-row input { width: 70px; }
        .volume-row label { font-size: 0.75em; color: #a0aec0; width: 28px; }
        .fullscreen-btn {
            position: fixed; top: 10px; right: 10px;
            padding: 8px 14px; background: rgba(0,0,0,0.7);
            border: 1px solid #4a5568; border-radius: 6px;
            color: #fff; cursor: pointer; z-index: 100; font-size: 0.9em;
        }
        .fullscreen-btn:hover { background: rgba(74,85,104,0.9); }
        :fullscreen .game-container { max-width: 100%; }
        :fullscreen #pagebody > *:not(.game-container):not(.music-controls):not(.fullscreen-btn) { display: none; }
        .mode-btns { display: flex; justify-content: center; gap: 8px; margin: 10px 0; }
        .mode-btn { padding: 6px 12px; background: rgba(0,0,0,0.3); border: 1px solid #4a5568; border-radius: 6px; color: #fff; cursor: pointer; font-size: 0.85em; }
        .mode-btn:hover { border-color: #68d391; }
        .mode-btn.active { border-color: #68d391; background: rgba(104,211,145,0.2); }
        .stats-modal { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); background: #2d3748; padding: 24px; border-radius: 12px; z-index: 200; min-width: 280px; }
        .stats-modal h3 { margin: 0 0 15px; }
        .stats-modal .close { position: absolute; top: 10px; right: 15px; cursor: pointer; font-size: 1.5em; }
        .stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; text-align: center; margin-bottom: 15px; }
        .stats-grid .num { font-size: 1.5em; font-weight: bold; }
        .stats-grid .label { font-size: 0.75em; color: #a0aec0; }
        .dist-bar { display: flex; align-items: center; gap: 8px; margin: 4px 0; }
        .dist-bar span:first-child { width: 12px; }
        .dist-bar .bar { height: 20px; background: #4a5568; border-radius: 3px; min-width: 8px; display: flex; align-items: center; justify-content: flex-end; padding-right: 6px; font-size: 0.75em; }
        .dist-bar .bar.highlight { background: #68d391; }
        .share-btn { width: 100%; padding: 10px; background: #68d391; border: none; border-radius: 6px; color: #1a1a2e; font-weight: bold; cursor: pointer; margin-top: 10px; }
        .share-btn:hover { background: #48bb78; }
        .overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 199; }
        .hard-indicator { color: #fc8181; font-size: 0.8em; margin-left: 5px; }
    </style>
</head>
<body>
{{ macros.templates() }}
<div id="pagebody">
    {{ macros.topbar() }}
    <div class="game-container">
        <h1>Infinite Wordle</h1>
        <p class="subtitle">Guess the 5-letter word. Green = correct, Gold = wrong spot</p>
        <div id="board"></div>
        <div id="stats">
            <span>Attempts: <strong id="attempts">0</strong></span>
            <span>Streak: <strong id="streak">0</strong></span>
            <span>Best: <strong id="best">0</strong></span>
        </div>
        <div id="keyboard"></div>
        <div id="message"></div>
        <div class="mode-btns">
            <button class="mode-btn active" data-mode="normal">Normal</button>
            <button class="mode-btn" data-mode="hard">Hard</button>
            <button class="mode-btn" data-mode="daily">Daily</button>
        </div>
        <div class="btn-row">
            <button class="btn secondary" id="new-game">New Game</button>
            <button class="btn secondary" id="show-answer">Reveal</button>
            <button class="btn secondary" id="show-stats">Stats</button>
            <button class="btn" id="share-btn">Share</button>
        </div>
    </div>
    <button class="fullscreen-btn" id="fullscreen-btn">Fullscreen</button>
    <div class="music-controls">
        <button id="music-toggle">Play Music</button>
        <button id="music-next">Next</button>
        <div class="song-name" id="song-name"></div>
        <div class="volume-row"><label>SFX</label><input type="range" id="sfx-vol" min="0" max="100" value="70"></div>
        <div class="volume-row"><label>Music</label><input type="range" id="music-vol" min="0" max="100" value="50"></div>
    </div>
    {{ macros.footer() }}
</div>
<script>
(function(){
    const WORDS = [
        'about','above','abuse','actor','acute','admit','adopt','adult','after','again',
        'agent','agree','ahead','alarm','album','alert','alien','align','alike','alive',
        'allow','alone','along','alter','among','anger','angle','angry','apart','apple',
        'apply','arena','argue','arise','armor','array','arrow','asset','avoid','award',
        'aware','awful','basic','beach','begin','being','below','bench','berry','birth',
        'black','blade','blame','blank','blast','blaze','blend','bless','blind','block',
        'blood','bloom','blown','board','bonus','boost','booth','bound','brain','brand',
        'brave','bread','break','breed','brick','bride','brief','bring','broad','broke',
        'brown','brush','build','burst','buyer','cable','camel','candy','cargo','carry',
        'carve','catch','cause','chain','chair','chaos','charm','chart','chase','cheap',
        'check','chess','chest','chief','child','china','chose','chunk','civic','claim',
        'clash','class','clean','clear','clerk','click','cliff','climb','cling','clock',
        'close','cloth','cloud','coach','coast','coral','couch','could','count','court',
        'cover','crack','craft','crane','crash','crazy','cream','creek','creep','crime',
        'crisp','cross','crowd','crown','cruel','crush','curve','cycle','daily','dance',
        'dated','dealt','death','debug','debut','decay','decor','decoy','delay','delta'
    ];

    const audio = new GameAudio();
    let secret = '', attempts = 0, currentGuess = '', gameOver = false;
    let streak = 0, best = parseInt(localStorage.getItem('wordleBest')) || 0;
    let mode = 'normal', hardMode = false, guessHistory = [];
    const keyState = {}, revealedGreen = [], revealedGold = [];

    // Stats stored in localStorage
    let stats = JSON.parse(localStorage.getItem('wordleStats')) || {played:0,won:0,streak:0,maxStreak:0,dist:[0,0,0,0,0,0]};

    const testMode = new URLSearchParams(window.location.search).get('test') === 'true';
    let testPassed = false;

    const board = document.getElementById('board');
    const keyboard = document.getElementById('keyboard');

    // Volume & fullscreen
    document.getElementById('sfx-vol').oninput = e => audio.setSfxVolume(e.target.value/100);
    document.getElementById('music-vol').oninput = e => audio.setMusicVolume(e.target.value/100);
    document.getElementById('fullscreen-btn').onclick = () => {
        if(!document.fullscreenElement) document.documentElement.requestFullscreen();
        else document.exitFullscreen();
    };
    document.addEventListener('fullscreenchange', () => {
        document.getElementById('fullscreen-btn').textContent = document.fullscreenElement ? 'Exit' : 'Fullscreen';
    });

    // Mode buttons
    document.querySelectorAll('.mode-btn').forEach(btn => {
        btn.onclick = function() {
            document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            mode = this.dataset.mode;
            hardMode = mode === 'hard';
            init();
        };
    });

    function getDailyWord() {
        const d = new Date(), seed = d.getFullYear() * 10000 + (d.getMonth()+1) * 100 + d.getDate();
        return WORDS[seed % WORDS.length].toUpperCase();
    }

    function init() {
        if(mode === 'daily') {
            secret = getDailyWord();
            const today = new Date().toDateString();
            const played = localStorage.getItem('wordleDaily');
            if(played === today) {
                document.getElementById('message').textContent = 'Daily already played!';
                gameOver = true; return;
            }
        } else {
            secret = WORDS[Math.floor(Math.random() * WORDS.length)].toUpperCase();
        }
        attempts = 0; currentGuess = ''; gameOver = false; guessHistory = [];
        revealedGreen.length = 0; revealedGold.length = 0;
        Object.keys(keyState).forEach(k => delete keyState[k]);
        board.innerHTML = '';
        for(let i = 0; i < 6; i++) {
            const row = document.createElement('div'); row.className = 'row';
            for(let j = 0; j < 5; j++) { const tile = document.createElement('div'); tile.className = 'tile'; row.appendChild(tile); }
            board.appendChild(row);
        }
        renderKeyboard(); updateStats();
        document.getElementById('message').textContent = hardMode ? 'Hard Mode' : '';
        document.getElementById('show-answer').disabled = false;
    }

    function renderKeyboard() {
        const rows = ['QWERTYUIOP', 'ASDFGHJKL', 'ZXCVBNM'];
        keyboard.innerHTML = '';
        rows.forEach((row, ri) => {
            const kbRow = document.createElement('div'); kbRow.className = 'kb-row';
            if(ri === 2) { const enter = document.createElement('button'); enter.className = 'key wide'; enter.textContent = 'ENTER'; enter.onclick = () => submitGuess(); kbRow.appendChild(enter); }
            row.split('').forEach(k => {
                const key = document.createElement('button');
                key.className = 'key' + (keyState[k] ? ' ' + keyState[k] : '');
                key.textContent = k; key.onclick = () => addLetter(k);
                kbRow.appendChild(key);
            });
            if(ri === 2) { const back = document.createElement('button'); back.className = 'key wide'; back.textContent = 'DEL'; back.onclick = () => removeLetter(); kbRow.appendChild(back); }
            keyboard.appendChild(kbRow);
        });
    }

    function updateStats() {
        document.getElementById('attempts').textContent = attempts;
        document.getElementById('streak').textContent = streak;
        document.getElementById('best').textContent = best;
    }

    function getCurrentRow() { return board.children[attempts]; }

    function addLetter(l) {
        if(gameOver || currentGuess.length >= 5) return;
        audio.type(); currentGuess += l;
        const row = getCurrentRow(), tile = row.children[currentGuess.length - 1];
        tile.textContent = l; tile.classList.add('pop');
        setTimeout(() => tile.classList.remove('pop'), 150);
    }

    function removeLetter() {
        if(gameOver || currentGuess.length === 0) return;
        audio.click();
        getCurrentRow().children[currentGuess.length - 1].textContent = '';
        currentGuess = currentGuess.slice(0, -1);
    }

    function validateHardMode() {
        for(let i = 0; i < 5; i++) {
            if(revealedGreen[i] && currentGuess[i] !== revealedGreen[i]) {
                document.getElementById('message').textContent = `Must use ${revealedGreen[i]} in position ${i+1}`;
                return false;
            }
        }
        for(const l of revealedGold) {
            if(!currentGuess.includes(l)) {
                document.getElementById('message').textContent = `Must use ${l}`;
                return false;
            }
        }
        return true;
    }

    function submitGuess() {
        if(gameOver || currentGuess.length !== 5) {
            if(currentGuess.length !== 5) { getCurrentRow().classList.add('shake'); audio.wrong(); setTimeout(() => getCurrentRow().classList.remove('shake'), 300); }
            return;
        }
        if(hardMode && !validateHardMode()) { getCurrentRow().classList.add('shake'); audio.wrong(); setTimeout(() => getCurrentRow().classList.remove('shake'), 300); return; }

        const row = getCurrentRow(), guess = currentGuess;
        const colors = Array(5).fill('gray'), remaining = secret.split('');

        for(let i = 0; i < 5; i++) { if(guess[i] === secret[i]) { colors[i] = 'green'; remaining[i] = null; } }
        for(let i = 0; i < 5; i++) {
            if(colors[i] === 'green') continue;
            const idx = remaining.indexOf(guess[i]);
            if(idx !== -1) { colors[i] = 'gold'; remaining[idx] = null; }
        }

        guessHistory.push({guess, colors});
        for(let i = 0; i < 5; i++) {
            if(colors[i] === 'green') revealedGreen[i] = guess[i];
            else if(colors[i] === 'gold' && !revealedGold.includes(guess[i])) revealedGold.push(guess[i]);
        }

        for(let i = 0; i < 5; i++) {
            const tile = row.children[i];
            tile.style.animationDelay = (i * 0.1) + 's'; tile.classList.add('flip');
            setTimeout(() => {
                tile.classList.add(colors[i]);
                if(!keyState[guess[i]] || keyState[guess[i]] !== 'green') {
                    if(colors[i] === 'green' || (colors[i] === 'gold' && keyState[guess[i]] !== 'gold')) keyState[guess[i]] = colors[i];
                    else if(!keyState[guess[i]]) keyState[guess[i]] = colors[i];
                }
            }, i * 100 + 250);
        }

        setTimeout(() => {
            renderKeyboard();
            if(colors.includes('green')) audio.correct();
            else if(colors.includes('gold')) audio.combo(1);
            else audio.wrong();
        }, 500);

        attempts++; currentGuess = '';

        setTimeout(() => {
            updateStats();
            if(guess === secret) {
                gameOver = true; streak++;
                if(streak > best) { best = streak; localStorage.setItem('wordleBest', best); }
                stats.played++; stats.won++; stats.streak++; stats.maxStreak = Math.max(stats.maxStreak, stats.streak);
                stats.dist[attempts-1]++; localStorage.setItem('wordleStats', JSON.stringify(stats));
                if(mode === 'daily') localStorage.setItem('wordleDaily', new Date().toDateString());
                updateStats();
                document.getElementById('message').textContent = `Won in ${attempts}!`;
                document.getElementById('message').classList.add('bounce');
                audio.victory();
            } else if(attempts >= 6) {
                gameOver = true; streak = 0;
                stats.played++; stats.streak = 0; localStorage.setItem('wordleStats', JSON.stringify(stats));
                updateStats();
                document.getElementById('message').textContent = `The word was ${secret}`;
                audio.gameOver();
            }
        }, 600);
    }

    function showStatsModal() {
        const overlay = document.createElement('div'); overlay.className = 'overlay';
        const modal = document.createElement('div'); modal.className = 'stats-modal';
        const maxDist = Math.max(...stats.dist, 1);
        modal.innerHTML = `<span class="close">&times;</span><h3>Statistics</h3>
            <div class="stats-grid">
                <div><div class="num">${stats.played}</div><div class="label">Played</div></div>
                <div><div class="num">${stats.played ? Math.round(stats.won/stats.played*100) : 0}</div><div class="label">Win %</div></div>
                <div><div class="num">${stats.streak}</div><div class="label">Streak</div></div>
                <div><div class="num">${stats.maxStreak}</div><div class="label">Max</div></div>
            </div>
            <div><strong>Guess Distribution</strong></div>
            ${stats.dist.map((n,i) => `<div class="dist-bar"><span>${i+1}</span><div class="bar${gameOver && attempts === i+1 ? ' highlight' : ''}" style="width:${Math.max(8, n/maxDist*100)}%">${n}</div></div>`).join('')}
            <button class="share-btn" id="modal-share">Share</button>`;
        document.body.appendChild(overlay); document.body.appendChild(modal);
        modal.querySelector('.close').onclick = () => { overlay.remove(); modal.remove(); };
        overlay.onclick = () => { overlay.remove(); modal.remove(); };
        modal.querySelector('#modal-share').onclick = shareResult;
    }

    function shareResult() {
        if(!gameOver) return;
        const emoji = guessHistory.map(g => g.colors.map(c => c === 'green' ? '🟩' : c === 'gold' ? '🟨' : '⬛').join('')).join('\n');
        const text = `Infinite Wordle ${mode === 'daily' ? 'Daily' : ''} ${attempts}/6${hardMode ? '*' : ''}\n\n${emoji}`;
        navigator.clipboard.writeText(text).then(() => {
            document.getElementById('message').textContent = 'Copied to clipboard!';
        });
    }

    document.addEventListener('keydown', e => {
        if(e.ctrlKey || e.metaKey || e.altKey) return;
        const k = e.key.toUpperCase();
        if(k === 'ENTER') submitGuess();
        else if(k === 'BACKSPACE') removeLetter();
        else if(k.length === 1 && k >= 'A' && k <= 'Z') addLetter(k);
    });

    document.getElementById('new-game').onclick = () => { if(mode !== 'daily') { streak = 0; init(); } };
    document.getElementById('show-answer').onclick = function() {
        document.getElementById('message').textContent = `Answer: ${secret}`;
        this.disabled = true; streak = 0; updateStats();
    };
    document.getElementById('show-stats').onclick = showStatsModal;
    document.getElementById('share-btn').onclick = shareResult;

    let musicPlaying = false;
    document.getElementById('music-toggle').onclick = function() {
        if(musicPlaying) { audio.stopMusic(); this.textContent = 'Play Music'; }
        else { audio.startMusic(); this.textContent = 'Mute'; document.getElementById('song-name').textContent = audio.getSongName(); }
        musicPlaying = !musicPlaying;
    };
    document.getElementById('music-next').onclick = function() {
        if(musicPlaying) { audio.nextSong(); document.getElementById('song-name').textContent = audio.getSongName(); }
    };

    if(testMode) {
        setTimeout(() => {
            if(testPassed) return;
            for(let i = 0; i < secret.length; i++) setTimeout(() => addLetter(secret[i]), i * 100);
            setTimeout(() => { submitGuess(); testPassed = true; console.log('TEST_PASSED'); document.body.insertAdjacentHTML('beforeend', '<div id="test-result" style="position:fixed;top:10px;left:10px;background:green;color:white;padding:10px;z-index:9999">TEST PASSED</div>'); }, secret.length * 100 + 200);
        }, 1000);
    }

    init();
})();
</script>
</body>
</html>
