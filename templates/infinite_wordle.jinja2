<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <title>Infinite Wordle</title>
    <script src="/static/js/piano-music.js"></script>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px;
            text-align: center;
            background: linear-gradient(to bottom, #f5f5f5, #e0e0e0);
            min-height: 100vh;
        }
        h1 {
            color: #333;
            font-size: 2.5em;
            margin-bottom: 10px;
        }
        #instructions {
            color: #666;
            margin-bottom: 20px;
        }
        #board {
            margin: 20px auto;
            max-width: 350px;
        }
        #board .row {
            margin-bottom: 5px;
        }
        .tile {
            display: inline-block;
            width: 50px;
            height: 50px;
            line-height: 50px;
            margin: 3px;
            color: white;
            font-weight: bold;
            text-transform: uppercase;
            font-size: 1.5em;
            border-radius: 5px;
            background: #d3d6da;
            border: 2px solid #d3d6da;
            animation: flip 0.5s ease forwards;
        }
        .tile.green {
            background: #6aaa64;
            border-color: #6aaa64;
            box-shadow: 0 0 10px rgba(106, 170, 100, 0.5);
        }
        .tile.gold {
            background: #c9b458;
            border-color: #c9b458;
            box-shadow: 0 0 10px rgba(201, 180, 88, 0.5);
        }
        .tile.gray {
            background: #787c7e;
            border-color: #787c7e;
        }
        @keyframes flip {
            0% { transform: rotateX(0deg); }
            50% { transform: rotateX(90deg); }
            100% { transform: rotateX(0deg); }
        }
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            50% { transform: translateX(10px); }
            75% { transform: translateX(-10px); }
        }
        @keyframes bounce {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.2); }
        }
        .shake-input {
            animation: shake 0.5s;
        }
        .win-message {
            animation: bounce 0.6s ease;
        }
        #guess {
            padding: 12px 20px;
            font-size: 16px;
            border: 2px solid #6aaa64;
            border-radius: 5px;
            margin: 10px 5px;
            text-transform: uppercase;
        }
        button {
            padding: 12px 20px;
            font-size: 16px;
            background: #6aaa64;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            margin: 5px;
            transition: all 0.3s;
        }
        button:hover {
            background: #5a9a54;
            transform: scale(1.05);
        }
        button:disabled {
            background: #ccc;
            cursor: not-allowed;
        }
        #message {
            font-size: 1.5em;
            font-weight: bold;
            color: #6aaa64;
            margin-top: 20px;
            min-height: 30px;
        }
        #attempts {
            font-size: 1.2em;
            color: #555;
            margin: 10px 0;
        }
        .music-controls {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: rgba(255, 255, 255, 0.9);
            padding: 10px 15px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            font-size: 0.9em;
        }
        .music-controls button {
            padding: 5px 10px;
            font-size: 14px;
            margin: 2px;
        }
        .music-controls .song-name {
            font-size: 0.85em;
            color: #666;
            margin-top: 5px;
        }
    </style>
</head>
<body>
<h1>Infinite Wordle</h1>
<p id="instructions">Type a 5-letter word and press Enter or Guess. Green means correct spot, gold means the letter is in the word.</p>
<div id="board"></div>
<p id="attempts">Attempts: 0</p>
<input id="guess" type="text" maxlength="5" placeholder="5-letter word">
<button id="submit">Guess</button>
<button id="new-game">New Game</button>
<button id="show-answer">Show Answer</button>
<div id="message"></div>

<div class="music-controls">
    <button id="music-toggle">🎵 Play Music</button>
    <button id="music-next">⏭️ Next</button>
    <div class="song-name" id="song-name"></div>
</div>

<script>
const words = ["apple","grape","banjo","chief","brave","crane","share","flint","prime","stone","chair","brand","sling","smile","sugar","tiger","bread","cargo","ghost","dream","eagle","level","media","night","ocean","proud","quick","rough","shine","toast"];
let secret = pickWord();
let attempts = 0;

// Procedural audio
const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

function playTone(freq, duration, type = 'sine') {
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.connect(gain);
    gain.connect(audioCtx.destination);
    osc.frequency.value = freq;
    osc.type = type;
    gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + duration);
    osc.start(audioCtx.currentTime);
    osc.stop(audioCtx.currentTime + duration);
}

function playCorrect() {
    playTone(523.25, 0.1);
    setTimeout(() => playTone(659.25, 0.15), 100);
}

function playYellow() {
    playTone(392, 0.1);
}

function playWrong() {
    playTone(261.63, 0.15, 'sawtooth');
}

function playWin() {
    [261.63, 329.63, 392, 523.25].forEach((f, i) => {
        setTimeout(() => playTone(f, 0.2), i * 100);
    });
}

function playInvalid() {
    playTone(200, 0.1, 'square');
    setTimeout(() => playTone(150, 0.15, 'square'), 100);
}

function pickWord() {
    return words[Math.floor(Math.random() * words.length)].toUpperCase();
}

function newGame() {
    secret = pickWord();
    attempts = 0;
    document.getElementById('board').innerHTML = '';
    document.getElementById('message').textContent = '';
    document.getElementById('attempts').textContent = 'Attempts: 0';
    document.getElementById('show-answer').disabled = false;
}

function evaluateGuess(guess) {
    guess = guess.toUpperCase();
    let result = '';
    let secretRemaining = secret.split('');
    const colors = Array(5).fill('gray');
    let hasGreen = false, hasYellow = false;

    for (let i = 0; i < 5; i++) {
        if (guess[i] === secret[i]) {
            colors[i] = 'green';
            secretRemaining[i] = null;
            hasGreen = true;
        }
    }
    for (let i = 0; i < 5; i++) {
        if (colors[i] === 'green') continue;
        const idx = secretRemaining.indexOf(guess[i]);
        if (idx !== -1) {
            colors[i] = 'gold';
            secretRemaining[idx] = null;
            hasYellow = true;
        }
    }
    for (let i = 0; i < 5; i++) {
        result += `<span class="tile ${colors[i]}" style="animation-delay: ${i * 0.1}s">${guess[i]}</span>`;
    }

    if (hasGreen) playCorrect();
    else if (hasYellow) playYellow();
    else playWrong();

    return result;
}

document.getElementById('submit').onclick = function() {
    const guessField = document.getElementById('guess');
    const guess = guessField.value;
    if (guess.length !== 5) {
        guessField.classList.add('shake-input');
        playInvalid();
        setTimeout(() => guessField.classList.remove('shake-input'), 500);
        return;
    }
    document.getElementById('board').innerHTML += `<div class="row">${evaluateGuess(guess)}</div>`;
    attempts++;
    document.getElementById('attempts').textContent = `Attempts: ${attempts}`;
    if (guess.toUpperCase() === secret) {
        const msg = document.getElementById('message');
        msg.textContent = `🎉 You win in ${attempts} guesses!`;
        msg.classList.add('win-message');
        playWin();
    }
    guessField.value = '';
    guessField.focus();
};

document.getElementById('new-game').onclick = newGame;
document.getElementById('guess').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
        document.getElementById('submit').click();
    }
});
document.getElementById('show-answer').onclick = function() {
    document.getElementById('message').textContent = `Answer: ${secret}`;
    this.disabled = true;
};

// Initialize background music
const musicGen = new PianoMusicGenerator();
let musicPlaying = false;

document.getElementById('music-toggle').onclick = function() {
    if (musicPlaying) {
        musicGen.stop();
        this.textContent = '🎵 Play Music';
        musicPlaying = false;
    } else {
        musicGen.start();
        this.textContent = '🔇 Mute Music';
        document.getElementById('song-name').textContent = `♪ ${musicGen.getCurrentSongName()}`;
        musicPlaying = true;
    }
};

document.getElementById('music-next').onclick = function() {
    if (musicPlaying) {
        musicGen.nextSong();
        document.getElementById('song-name').textContent = `♪ ${musicGen.getCurrentSongName()}`;
    }
};
</script>
</body>
</html>
