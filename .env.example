# Local debug mode
LOCAL_DEBUG=false

# Database
WORDGAMES_DB=/data/wordgames.db

# Stripe keys
STRIPE_TEST_SECRET=sk_test_xxx
STRIPE_TEST_KEY=pk_test_xxx
STRIPE_LIVE_SECRET=sk_live_xxx
STRIPE_LIVE_KEY=pk_live_xxx

# R2/S3 for static assets
AWS_ACCESS_KEY_ID=your_r2_access_key
AWS_SECRET_ACCESS_KEY=your_r2_secret_key
S3_BUCKET=your_bucket_name
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# GCP credentials (if still needed for migration)
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-credentials.json
